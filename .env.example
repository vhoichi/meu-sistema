# ==========================================================================
# Exemplo de variáveis de ambiente. Copie para .env.local e preencha os valores.
# NÃO comite o .env.local (já está no .gitignore).
# No Vercel, cadastre estas mesmas variáveis em Project Settings > Environment Variables.
# ==========================================================================

# ---- Supabase (uso server-side) ----
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=seu_service_role_key_aqui

# ---- Chaves públicas do Supabase (opcional; não usadas no fluxo atual) ----
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=seu_anon_public_key_aqui

# ---- Credenciais de login do sistema ----
APP_USER=seu_usuario@exemplo.com
APP_PASSWORD=sua_senha

# ---- Segredo para assinar o cookie de sessão (gere uma string aleatória) ----
SESSION_SECRET=gere_uma_string_aleatoria_longa
