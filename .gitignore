.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# ---- Vercel ----
.vercel

# ---- Claude Code (preview helper local) ----
.claude/

# ---- Logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# ---- TypeScript ----
*.tsbuildinfo

# ---- OS / Editor ----
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# ---- Data files (do not commit uploaded / source datasets) ----
*.csv
